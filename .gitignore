# =============================================================================
# .gitignore
# -----------------------------------------------------------------------------
# Specifies files and directories Git should NOT track.
# These are typically generated files, secrets, or OS/editor artifacts
# that don't belong in version control.
# =============================================================================

# --- Python ------------------------------------------------------------------
__pycache__/          # Compiled Python bytecode cache
*.py[cod]             # .pyc, .pyo, .pyd compiled files
*.egg-info/           # Packaging metadata
.venv/                # Virtual environment (never commit this)
venv/
dist/                 # Build output
build/

# --- Docker ------------------------------------------------------------------
.docker/              # Local Docker context cache

# --- Environment & Secrets ---------------------------------------------------
# ⚠️  NEVER commit secrets, API keys, or credentials to version control!
.env                  # Environment variable files
.env.local
.env.production
*.pem                 # SSL/TLS private keys
secrets/              # Any secrets folder

# --- Operating System --------------------------------------------------------
.DS_Store             # macOS folder metadata
Thumbs.db             # Windows thumbnail cache
desktop.ini

# --- IDE / Editor ------------------------------------------------------------
.vscode/              # VS Code workspace settings
.idea/                # JetBrains IDE settings
*.swp                 # Vim swap files
*.swo

# --- Logs --------------------------------------------------------------------
*.log
logs/
